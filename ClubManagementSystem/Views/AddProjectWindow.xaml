<Window x:Class="ClubManagementSystem.Views.AddProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proje Yönetim Modalı" Height="600" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="24" BorderBrush="#E2E8F0" BorderThickness="1" Padding="35">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="2" Color="#1D333F" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="TÜBİTAK Proje Girişi" FontSize="24" FontWeight="Bold" Foreground="#1D333F" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <StackPanel Grid.Row="1" Margin="5,0,5,0">
                <TextBlock Text="Proje Kodu / Program Türü" Margin="0,0,0,6" Foreground="#78909C" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtProjectCode" Height="48" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="12,0" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,16">
                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></TextBox.Resources>
                </TextBox>

                <TextBlock Text="Proje Başlığı (Adı)" Margin="0,0,0,6" Foreground="#78909C" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtProjectName" Height="48" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="12,0" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,16">
                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></TextBox.Resources>
                </TextBox>

                <TextBlock Text="Akademik Danışman" Margin="0,0,0,6" Foreground="#78909C" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtAdvisorName" Height="48" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="12,0" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,16">
                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></TextBox.Resources>
                </TextBox>

                <TextBlock Text="Mevcut Başvuru Durumu" Margin="0,0,0,6" Foreground="#78909C" FontSize="13" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbStatus" Height="48" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="12,0,0,0" FontSize="14" VerticalContentAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="Başvuru Aşamasında"/>
                    <ComboBoxItem Content="Onaylandı / Devam Ediyor"/>
                    <ComboBoxItem Content="Tamamlandı"/>
                    <ComboBoxItem Content="Reddedildi"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Kapat" Width="100" Height="46" Background="Transparent" Foreground="#78909C" BorderThickness="0" FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="BtnCancel_Click" Margin="0,0,12,0"/>
                <Button Content="Projeyi Kaydet" Width="150" Height="46" Background="#FF9800" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>