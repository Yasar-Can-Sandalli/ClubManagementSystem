<Window x:Class="ClubManagementSystem.Views.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="Üye İşlemleri" Height="650" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F4F6F8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F4F6F8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="25" BorderBrush="#E2E8F0" BorderThickness="1" Padding="40">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="2" Color="Gray" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Üye Bilgi Formu" FontSize="26" FontWeight="Bold" Foreground="#1D333F" Margin="0,0,0,30" HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Adı:" FontSize="13" Foreground="#78909C" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtFirstName"/>

                <TextBlock Text="Soyadı:" FontSize="13" Foreground="#78909C" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtLastName"/>

                <TextBlock Text="Öğrenci Numarası:" FontSize="13" Foreground="#78909C" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtStudentNumber"/>

                <TextBlock Text="Bölümü (Örn: Bilgisayar Müh.):" FontSize="13" Foreground="#78909C" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtDepartment"/>

                <TextBlock Text="Kulüp Rolü:" FontSize="13" Foreground="#78909C" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbRole" SelectedIndex="0">
                    <ComboBoxItem Content="Yönetim Kurulu Başkanı"/>
                    <ComboBoxItem Content="Yönetim Kurulu Üyesi"/>
                    <ComboBoxItem Content="Aktif Üye"/>
                    <ComboBoxItem Content="Aday Üye"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="İptal" Width="100" Height="46" FontSize="15" Background="Transparent" Foreground="#78909C" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="Değişiklikleri Kaydet" Width="180" Height="46" FontSize="15" FontWeight="SemiBold" Background="#623ED0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>