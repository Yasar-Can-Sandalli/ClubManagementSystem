<Window x:Class="ClubManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="ROTOM DX Kulüp Yönetimi" Height="800" Width="1300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="20,6,20,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NavIconStyle" TargetType="iconPacks:PackIconMaterial">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="20,0,18,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Foreground" Value="#623ED0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NavTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Foreground" Value="#1D333F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#F0F7F7" CornerRadius="30" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="30,0,0,30" Padding="0,30,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="1" Color="Gray" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> 
                        <RowDefinition Height="Auto"/> 
                        <RowDefinition Height="*"/>    
                        <RowDefinition Height="Auto"/> 
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,35">
                        <iconPacks:PackIconMaterial Kind="RocketLaunch" Foreground="#623ED0" Width="28" Height="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ROTOM DX" Foreground="#1D333F" FontSize="26" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <Border Width="110" Height="110" CornerRadius="55" BorderThickness="4" BorderBrush="#623ED0" Margin="0,0,0,15">
                            <Border.Background>
                                <ImageBrush ImageSource="/Images/profil.jpg" Stretch="UniformToFill">
                                    <ImageBrush.RelativeTransform>
                                        <RotateTransform Angle="0" CenterX="0.5" CenterY="0.5"/> 
                                    </ImageBrush.RelativeTransform>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Yaşar Can" Foreground="#1D333F" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock Text="Kulüp Başkanı" Foreground="#78909C" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Click="BtnDashboard_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal" Width="240">
                                <iconPacks:PackIconMaterial Kind="ViewDashboardOutline" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Dashboard" Style="{StaticResource NavTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnMembers_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal" Width="240">
                                <iconPacks:PackIconMaterial Kind="AccountGroupOutline" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Üyeler" Style="{StaticResource NavTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnEvents_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal" Width="240">
                                <iconPacks:PackIconMaterial Kind="CalendarClockOutline" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Etkinlikler" Style="{StaticResource NavTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnProjects_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal" Width="240">
                                <iconPacks:PackIconMaterial Kind="LightbulbOnOutline" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="TÜBİTAK Projeleri" Style="{StaticResource NavTextStyle}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Grid.Row="3" Click="BtnLogout_Click" Height="50" Margin="30,0" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Logout" Foreground="#E53935" Width="20" Height="20" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Güvenli Çıkış" Foreground="#E53935" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="0,30,30,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,15,30,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand" Margin="0,0,10,0">
                                <iconPacks:PackIconMaterial Kind="WindowMinimize" Foreground="#AAAAAA" Width="16" Height="16"/>
                            </Button>
                            <Button x:Name="BtnClose" Click="BtnClose_Click" Background="Transparent" BorderThickness="0" Width="35" Height="35" Cursor="Hand">
                                <iconPacks:PackIconMaterial Kind="Close" Foreground="#AAAAAA" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="MainContent" Grid.Row="1">
                        </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>